# OpenPortfolio env vars. Copy to `.env` and fill in.
# In production, `fly secrets set KEY=value -a openportfolio` instead.

# ---- auth (required) -----------------------------------------------------
# 32-byte random string. Sent via X-Admin-Token header.
#   python -c 'import secrets; print(secrets.token_urlsafe(32))'
ADMIN_TOKEN=

# ---- storage -------------------------------------------------------------
# Prod mount is /data on the Fly volume `op_data`. Override for local dev:
# DATABASE_URL=sqlite:///./dev.db

# ---- LLM: Azure OpenAI (default) ----------------------------------------
LLM_PROVIDER=azure
AZURE_API_KEY=
AZURE_API_BASE=https://<resource>.openai.azure.com
AZURE_API_VERSION=2025-03-01-preview
AZURE_DEPLOYMENT_NAME=

# ---- LLM: Ollama (local alternative) ------------------------------------
# Uncomment to switch. Leave Azure vars blank.
# LLM_PROVIDER=ollama
# LLM_MODEL=llama3.1
# OLLAMA_API_BASE=http://host.docker.internal:11434
